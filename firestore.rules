rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /posts/{userId}/{fileId} {
      allow read: if true; // Or if request.auth != null for private
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /profiles/{userId}/{fileId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}